# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://hrm:hrm_dev_password@localhost:5432/sample_hrm
DB_HOST=localhost
DB_PORT=5432
DB_USER=hrm
DB_PASSWORD=hrm_dev_password
DB_NAME=sample_hrm
DB_SYNCHRONIZE=false
DB_LOGGING=false

# JWT (httpOnly cookies)
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=replace-me-with-another-long-random-string
REFRESH_TOKEN_EXPIRES_IN=7d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict

# Mail (SMTP / MailHog in dev)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@sample-hrm.com

# AWS S3 (file uploads)
S3_REGION=us-east-1
S3_BUCKET=sample-hrm-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Slack (Emergency Leave channel webhook)
SLACK_WEBHOOK_URL=
SLACK_EMERGENCY_CHANNEL=#emergency-leaves
SLACK_BOT_TOKEN=

# Gather Town (Attendance auto-tracking)
GATHER_API_KEY=
GATHER_SPACE_ID=
GATHER_SYNC_INTERVAL_SECONDS=60

# Notion (Daily notes)
NOTION_API_TOKEN=
NOTION_DATABASE_ID=
NOTION_SYNC_INTERVAL_MINUTES=15

# Office Configuration (defaults; stored in DB and editable by HR Admin)
DEFAULT_OFFICE_START_TIME=08:00
DEFAULT_OFFICE_END_TIME=17:00
DEFAULT_CORE_HOURS_START=08:00
DEFAULT_CORE_HOURS_END=13:00
DEFAULT_GRACE_PERIOD_MINUTES=10

# Security
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Sentry (optional)
SENTRY_DSN=
